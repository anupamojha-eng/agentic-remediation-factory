# Copy this file to .env and fill in your credentials.
# Never commit .env — it is gitignored.

# GitHub Personal Access Token — needs: repo, workflow
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_your_token_here

# ── LLM provider (set ONE or BOTH; Anthropic is preferred when both are set) ──

# Anthropic Claude — recommended for best accuracy on complex multi-file patches
# Default model: claude-opus-4-8  (override with ANTHROPIC_MODEL=claude-sonnet-4-6)
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Google Gemini — cost-effective alternative (Gemini 2.5 Flash)
# Override model with GEMINI_MODEL=gemini-2.5-pro
# Create at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Force a specific provider when both keys are set (optional)
# LLM_PROVIDER=anthropic   # or: gemini
